# m5-petit-env 設定ファイル(サンプル)
# 使い方: cp .env.example .env  してから値を編集する

# --- 基本設定 ---
TZ=Asia/Tokyo

# 動かすキャラクターID(カンマ区切り)。/data/characters/<id> に対応するデータが必要。
# sample-character/ をコピーして characters/<id> を作るところから始める。
CHARACTER_IDS=alice

# ダッシュボード(FastAPI)を公開するホスト側ポート
DASHBOARD_PORT=8765

# --- M5デバイス接続先 ---
# 各キャラのM5(M5Stack CoreS3)のIPアドレスを指定する。
# コンテナ内から mDNS(.local ホスト名)は解決できないことが多いため、IP指定を基本とする。
# 変数名は M5_HOSTS_<CHARACTER_IDを大文字化したもの> (例: alice → M5_HOSTS_ALICE)
# 値は例示のIPアドレス(192.168.x.x)を実際のM5のIPに書き換えること。
M5_HOSTS_ALICE=192.168.1.50

# --- Claude認証 ---
# claude CLIの認証は、コンテナ起動後に一度だけ以下を実行して行う想定:
#   docker compose run --rm core claude login
# ANTHROPIC_API_KEY はサブスクリプション認証(claude login)を使う場合は通常不要。
# APIキー課金にしたい場合のみ設定する。
# ANTHROPIC_API_KEY=

# --- 音声(TTS/ASR、任意) ---
# 外部GPUマシンでTTS/ASRサーバー(m5-petit-speech / m5-petit-voice-recognition)を
# 動かしている場合はそのURLを指定する。未設定の場合はCPUフォールバック、もしくは
# 音声なし構成として動く(m5-petit-mcpのVOICE_API_HOST関連の環境変数を参照)。
# SPEECH_API_URL=http://gpu-host:8766
# ASR_API_URL=http://gpu-host:8767

# --- コンポーネントリポジトリのブランチ (scripts/sync-repos.sh が参照) ---
M5_PETIT_MCP_BRANCH=main
M5_PETIT_APP_BRANCH=main
M5_PETIT_MEMORY_BRANCH=main
M5_PETIT_DESIRE_BRANCH=main
M5_PETIT_SCRIPTS_BRANCH=main

# 音声コンポーネントはオプション(WITH_SPEECH=1のときだけ sync-repos.sh が取得する)
WITH_SPEECH=0
M5_PETIT_SPEECH_BRANCH=main
M5_PETIT_VOICE_RECOGNITION_BRANCH=main
